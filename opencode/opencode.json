{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "sudo *": "ask"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "thinking": false
      },
      "models": {
        "qwen25:fast": {
          "name": "Qwen2.5 Fast",
          "tools": true,
          "reasoning": false,
          "vision": false
        },
        "qwen25coder:stable": {
          "name": "Qwen2.5-coder Stable",
          "tools": true,
          "reasoning": false,
          "vision": false
        },
        "qwen3:balanced": {
          "name": "Qwen3 Balanced",
          "tools": true,
          "reasoning": true,
          "vision": false
        },
        "qwen35:fast": {
          "name": "Qwen3.5 Fast",
          "tools": true,
          "reasoning": false,
          "vision": false
        },
        "qwen35:precision": {
          "name": "Qwen3.5 Precision",
          "tools": true,
          "reasoning": true,
          "vision": false
        }
      }
    }
  },
  "model": "qwen3:balanced"
}
