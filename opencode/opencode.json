{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "ls": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "curl *": "ask",
      "wget *": "ask",
      "bash *": "ask",
      "sh *": "ask",
      "python *": "ask",
      "node *": "ask",
      "sudo *": "ask",
      "rm *": "deny",
      "rm -rf *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "chmod 777 *": "deny",
      ":(){ :|:& };:": "deny"
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "thinking": false
      },
      "models": {
        "omnicoder:optimized": {
          "name": "Omnicoder Optimized",
          "tools": true,
          "reasoning": true,
          "vision": false
        },
        "qwen25coder:stable": {
          "name": "Qwen2.5-coder Stable",
          "tools": true,
          "reasoning": true,
          "vision": false
        },
        "qwen3:balanced": {
          "name": "Qwen3 Balanced",
          "tools": true,
          "reasoning": false,
          "vision": false
        },
        "qwen35:balanced": {
          "name": "Qwen3.5 Balanced",
          "tools": true,
          "reasoning": false,
          "vision": false
        },
        "qwen35:precision": {
          "name": "Qwen3.5 Precision",
          "tools": true,
          "reasoning": true,
          "vision": false
        }
      }
    }
  },
  "model": "qwen3:balanced"
}
